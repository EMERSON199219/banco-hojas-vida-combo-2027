rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isPublicCreate(recordId) {
      return request.auth == null
        && request.resource != null
        && request.resource.data.id == recordId
        && recordId.matches('doc_[0-9]{5,20}')
        && request.resource.data.documentId is string
        && request.resource.data.documentId.matches('[0-9]{5,20}')
        && ('doc_' + request.resource.data.documentId) == recordId
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.profile is string
        && request.resource.data.familyReference is string
        && request.resource.data.phone is string
        && request.resource.data.availableOtherCity is string
        && request.resource.data.email is string
        && request.resource.data.createdAt is string;
    }

    match /combo2027_records/{recordId} {
      allow read: if true;
      allow create: if isPublicCreate(recordId);
      allow update, delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
