rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo usuarios autenticados pueden leer/escribir registros.
    match /combo2027_records/{recordId} {
      allow read, write: if request.auth != null;
    }

    // Deniega todo lo no definido explicitamente.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
